# =============================================================================
# Akeyless (required for make test-api / make validate / decK)
# =============================================================================
AKEYLESS_GATEWAY_URL=https://api.akeyless.io
AKEYLESS_ACCESS_ID=p-xxxxxxxx
AKEYLESS_ACCESS_KEY=

# Static secret your Access ID can read (create via ./scripts/setup-demo-secrets.sh)
AKEYLESS_DEMO_SECRET_PATH=/kong/demo/api-key
AKEYLESS_DEMO_SECRET_VALUE=change-me-in-akeyless

# Kong vault: full path = AKEYLESS_PATH_PREFIX + "/" + <resource>
# Example: /kong + /demo/api-key  =>  {vault://akeyless-vault/demo/api-key}
AKEYLESS_PATH_PREFIX=/kong

# =============================================================================
# Kong Gateway Enterprise (only for docker compose — optional for test-api)
# =============================================================================
# KONG_LICENSE_DATA='{"license":{"payload":{...},"signature":"..."}}'
KONG_LICENSE_DATA=
