# =============================================================================
# Akeyless credentials (required for make test-api / make validate step 1)
# =============================================================================
AKEYLESS_GATEWAY_URL=https://api.akeyless.io
AKEYLESS_ACCESS_ID=p-xxxxxxxx
AKEYLESS_ACCESS_KEY=

# Full path to a static secret your Access ID can READ.
# Must exist in Akeyless before running make test-api or make validate.
#
# Default matches setup-demo-secrets.sh:
AKEYLESS_DEMO_SECRET_PATH=/kong/demo/api-key
AKEYLESS_DEMO_SECRET_VALUE=change-me-in-akeyless
#
# Example: if you already have a secret at /demo/dotnet-integration, use:
# AKEYLESS_DEMO_SECRET_PATH=/demo/dotnet-integration
# AKEYLESS_PATH_PREFIX=

# Kong vault path_prefix in examples/kong.yaml (default /kong).
# Kong reference {vault://akeyless-vault/<resource>} resolves to:
#   AKEYLESS_PATH_PREFIX + "/" + resource  ==  AKEYLESS_DEMO_SECRET_PATH
AKEYLESS_PATH_PREFIX=/kong

# =============================================================================
# Kong Gateway Enterprise license (only for Docker Compose / Kong steps)
# =============================================================================
# NOT required for: make test-api  (Akeyless-only smoke test)
# Required for:     docker compose up  and  make validate step 2+
#
# What it is: your Kong Gateway Enterprise license payload (JSON string).
# Kong passes it as the KONG_LICENSE_DATA environment variable.
#
# How to get it:
#   - Kong Konnect: Organization → License → copy license data
#   - Kong trial:   https://konghq.com/get-started or ask your Kong AE
#   - Quickstart:   export KONG_LICENSE_DATA='<paste license JSON here>'
#
# Format: usually a single-line JSON object, e.g.:
#   KONG_LICENSE_DATA='{"license":{"payload":{...},"signature":"..."}}'
#
# Leave empty to skip Kong steps in make validate (Akeyless-only test still runs).
KONG_LICENSE_DATA=

# =============================================================================
# decK (optional — used when applying examples/kong.yaml)
# =============================================================================
DECK_AKEYLESS_GATEWAY_URL=https://api.akeyless.io
DECK_AKEYLESS_ACCESS_ID=p-xxxxxxxx
DECK_AKEYLESS_ACCESS_KEY=

# Override Kong vault reference parts (optional; auto-derived from paths above)
# AKEYLESS_VAULT_PREFIX=akeyless-vault
# AKEYLESS_VAULT_RESOURCE=demo/api-key
