# Kong Gateway Enterprise license (JSON, single line)
KONG_LICENSE_DATA=

# Akeyless bootstrap credentials
AKEYLESS_GATEWAY_URL=https://api.akeyless.io
AKEYLESS_ACCESS_ID=p-xxxxxxxx
AKEYLESS_ACCESS_KEY=

# Prefix for secrets referenced as {vault://akeyless-vault/<resource>}
# Full Akeyless path = AKEYLESS_PATH_PREFIX + "/" + resource
AKEYLESS_PATH_PREFIX=/kong

# decK environment variable names (used in examples/kong.yaml)
DECK_AKEYLESS_GATEWAY_URL=https://api.akeyless.io
DECK_AKEYLESS_ACCESS_ID=p-xxxxxxxx
DECK_AKEYLESS_ACCESS_KEY=

# Secret path used by scripts/validate-vault.sh
AKEYLESS_DEMO_SECRET_PATH=/kong/demo/api-key
AKEYLESS_DEMO_SECRET_VALUE=change-me-in-akeyless
